# Database
DATABASE_URL=postgresql://schoolpilot:schoolpilot_dev@localhost:5432/schoolpilot

# Redis
REDIS_URL=redis://:schoolpilot_d3v!Redis2025@localhost:6380

# Server
PORT=4000
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:4000

# Session
SESSION_SECRET=<generate-a-random-32-byte-secret>

# JWT (for GoPilot-style token auth)
JWT_SECRET=<generate-a-random-32-byte-secret>
JWT_EXPIRY=7d

# Device JWT (for ClassPilot Chrome extension)
STUDENT_TOKEN_SECRET=<generate-a-random-32-byte-secret>
CLASSPILOT_EXTENSION_ID=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY=

# SendGrid (optional for local dev)
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@example.com
ADMIN_EMAIL=admin@example.com

# Stripe (optional for local dev)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# AI providers (optional for local dev; required for AI chat + content classification)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Error tracking — Sentry (OPTIONAL, GATED OFF by default).
# Leave BLANK until you have (1) signed Sentry's DPA and (2) added Sentry to the
# public subprocessors list. When blank, no error data leaves the system; the
# durable error_logs Postgres table still captures everything regardless.
SENTRY_DSN=

# Developer error alerts via Telegram (optional). If unset, Telegram alerts are
# silently skipped (email alerts to ADMIN_EMAIL still fire).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Super Admin
SUPER_ADMIN_EMAIL=admin@example.com

# CORS (comma-separated frontend origins)
CORS_ALLOWLIST=http://localhost:5000,http://localhost:3000,http://localhost:5173,http://localhost:5174
