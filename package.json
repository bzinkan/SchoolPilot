{
  "name": "schoolpilot-api",
  "version": "1.0.0",
  "description": "Unified API for SchoolPilot (PassPilot + GoPilot + ClassPilot)",
  "type": "module",
  "engines": {
    "node": ">=22.9"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "migrate:startup": "node -e \"process.env.RUN_MIGRATIONS_ONLY='true'; import('./dist/index.js')\"",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx seeds/run.ts",
    "check": "tsc --noEmit",
    "soc2:check": "node scripts/soc2/check-governance-evidence.mjs",
    "soc2:privileged-access-evidence": "node scripts/soc2/collect-privileged-access-evidence.mjs",
    "soc2:privileged-access-private-evidence-kit": "node scripts/soc2/privileged-access-private-evidence-kit.mjs",
    "soc2:monitoring-evidence": "node scripts/soc2/collect-monitoring-evidence.mjs",
    "soc2:monitoring-private-evidence-kit": "node scripts/soc2/monitoring-private-evidence-kit.mjs",
    "soc2:ai-privacy-evidence": "node scripts/soc2/collect-ai-privacy-evidence.mjs",
    "soc2:ai-private-evidence-kit": "node scripts/soc2/ai-private-evidence-kit.mjs",
    "soc2:incident-evidence": "node scripts/soc2/collect-incident-evidence.mjs",
    "soc2:incident-private-evidence-kit": "node scripts/soc2/incident-private-evidence-kit.mjs",
    "soc2:tenant-isolation-evidence": "node scripts/soc2/collect-tenant-isolation-evidence.mjs",
    "soc2:deployment-evidence": "node scripts/soc2/collect-deployment-evidence.mjs",
    "soc2:private-evidence-readiness": "node scripts/soc2/private-evidence-readiness.mjs",
    "soc2:approval-queue": "node scripts/soc2/approval-queue.mjs",
    "soc2:approval-issue": "node scripts/soc2/github-approval-issue.mjs issue-body",
    "soc2:approval-decision": "node scripts/soc2/approval-queue.mjs decision",
    "load:classpilot": "node scripts/load/classpilot-load-test.mjs",
    "test": "node --env-file-if-exists=.env --import tsx --test \"tests/**/*.test.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.59.0",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "express-session": "^1.18.1",
    "googleapis": "^133.0.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "openai": "^6.44.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.22.0",
    "rate-limit-redis": "^4.3.1",
    "redis": "^6.0.1",
    "socket.io": "^4.7.4",
    "stripe": "^20.3.0",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.19.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.31.4",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3"
  }
}
