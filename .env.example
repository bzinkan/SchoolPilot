# Database
DATABASE_URL=postgresql://schoolpilot:schoolpilot_dev@localhost:5432/schoolpilot

# Redis
REDIS_URL=redis://:schoolpilot_d3v!Redis2025@localhost:6380
# Production Redis with required transit encryption must use rediss://...

# Server
PORT=4000
NODE_ENV=development
APP_ENV=development
PUBLIC_BASE_URL=http://localhost:4000
RUN_MIGRATIONS_ON_STARTUP=true
RUN_MIGRATIONS_ONLY=false
SCHEDULER_ENABLED=true
DB_POOL_MAX=50
SCHEDULER_DB_POOL_MAX=3

# Session — generate with: openssl rand -hex 32
SESSION_SECRET=

# JWT (for GoPilot-style token auth) — generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRY=7d

# Device JWT (for ClassPilot Chrome extension) — generate with: openssl rand -hex 32
STUDENT_TOKEN_SECRET=
CLASSPILOT_EXTENSION_ID=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY=

# Google Workspace roster connector (Domain-Wide Delegation)
# Preferred keyless mode: set GOOGLE_ROSTER_SA_EMAIL + GOOGLE_ROSTER_SA_CLIENT_ID
# and grant the runtime identity permission to sign JWTs for that service account.
# Fallback: set GOOGLE_ROSTER_SA_KEY_JSON to raw or base64 service-account JSON.
GOOGLE_ROSTER_SA_EMAIL=
GOOGLE_ROSTER_SA_CLIENT_ID=
GOOGLE_ROSTER_SA_KEY_JSON=

# SendGrid (optional for local dev)
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@example.com
ADMIN_EMAIL=admin@example.com

# Stripe (optional for local dev)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# AI providers (optional for local dev; required for AI chat + content classification)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# AI chat stays off unless explicitly enabled after privacy/subprocessor review.
AI_CHAT_ENABLED=false

# Error tracking — Sentry (OPTIONAL, GATED OFF by default).
# Leave BLANK until you have (1) signed Sentry's DPA and (2) added Sentry to the
# public subprocessors list. When blank, no error data leaves the system; the
# durable error_logs Postgres table still captures everything regardless.
SENTRY_DSN=

# Developer error alerts via Telegram (optional). If unset, Telegram alerts are
# silently skipped (email alerts to ADMIN_EMAIL still fire).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Super Admin
SUPER_ADMIN_EMAIL=admin@example.com

# Super Admin SOC 2 dashboard (optional locally; required in production for GitHub data/resync)
SOC2_DASHBOARD_GITHUB_TOKEN=
SOC2_DASHBOARD_REPO=bzinkan/SchoolPilot
SOC2_APPROVAL_ISSUE_NUMBER=146
SOC2_DASHBOARD_WORKFLOW=ci-build.yml

# CORS (comma-separated frontend origins)
CORS_ALLOWLIST=http://localhost:5000,http://localhost:3000,http://localhost:5173,http://localhost:5174

# Production RLS gate. Leave unset locally unless testing RLS behavior.
RLS_GUC_ENABLED=false
RLS_ENABLED_TABLES=
